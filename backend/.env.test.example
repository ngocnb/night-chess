# Integration test database — separate from dev so tests never touch real data.
#
# Setup (one-time):
#   psql -U nightchess -c "CREATE DATABASE nightchess_test;"
#
# Copy this file:
#   cp backend/.env.test.example backend/.env.test
#
# Run integration tests:
#   cd backend && pytest -m integration

TEST_DATABASE_URL=postgresql+asyncpg://nightchess:nightchess_dev@localhost:5432/nightchess_test
